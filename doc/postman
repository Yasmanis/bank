///////////SIN ARCHIVOS \\\\\\\\\\\\\\\\\
const secret = pm.variables.get("HMAC_SECRET");
// 2. Generar el timestamp en milisegundos
const timestamp = Date.now().toString();

// 3. Obtener el cuerpo de la petición (JSON)
// Si no hay body, usamos un string vacío
const body = pm.request.body.raw ? pm.request.body.raw : "";

// 4. Crear la firma (Timestamp + Body)
const dataToSign = timestamp + body;
const signature = CryptoJS.HmacSHA256(dataToSign, secret).toString();

// 5. Inyectar los headers automáticamente en la petición
pm.request.headers.add({key: 'X-Request-Timestamp', value: timestamp});
pm.request.headers.add({key: 'X-Request-Signature', value: signature});

console.log("Firma generada:", signature);


